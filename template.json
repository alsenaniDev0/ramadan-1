{
    "id": "ramadan-greeting",
    "name": "تهنئة رمضان فاخرة",
    "version": "1.0.0",
    "html": "index.html",
    "css": "style.css",
    "fields": [
        {
            "key": "message",
            "maxLength": 240,
            "type": "textarea",
            "required": true,
            "defaultValue": "بمناسبة حلول شهر رمضان المبارك، نسأل الله أن يجعله شهر خير وبركة ورحمة عليكم وعلى أحبابكم",
            "label": "نص التهنئة",
            "minLength": 5
        },
        {
            "type": "text",
            "label": "اسمك",
            "maxLength": 40,
            "placeholder": "مثال: محمد",
            "minLength": 2,
            "required": true,
            "key": "name",
            "defaultValue": "محمد"
        }
    ]
}